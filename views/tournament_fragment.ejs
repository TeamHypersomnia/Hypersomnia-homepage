<% if (!view) { %>
  <p class="tournament-empty">No tournament is currently in progress.</p>
<% } else { %>
  <% if (view.finished && view.winnerIndex >= 0) { %>
    <div class="tournament-winner">
      <h2 class="tournament-winner-label">WINNER</h2>
      <div class="team-card won">
        <%= view.teams[view.winnerIndex].label %>
      </div>
    </div>
    <hr class="tournament-separator">
  <% } %>

  <% if (view.stages.length === 0) { %>
    <p class="tournament-empty">No matches found.</p>
  <% } else { %>
    <div class="bracket-stack">
      <% const stagesNewestFirst = view.stages.slice().reverse(); %>
      <% stagesNewestFirst.forEach((stage, idx) => { %>
        <% if (idx > 0) { %>
          <hr class="tournament-separator stage-separator">
        <% } %>
        <div class="stage-section">
          <div class="stage-label <%= stage.current ? 'pulse' : '' %>"><%= stage.label %></div>

          <% stage.matches.forEach(m => {
               const leftIdx = m.resolved ? m.winner : m.teamA;
               const rightIdx = m.resolved ? (m.winner === m.teamA ? m.teamB : m.teamA) : m.teamB;
               const leftClass = m.resolved ? 'won' : (stage.current ? 'pulse' : '');
               const rightClass = m.resolved ? 'lost' : (stage.current ? 'pulse' : '');
               const left = view.teams[leftIdx];
               const right = view.teams[rightIdx];
          %>
            <%
              const hasScore = m.resolved && m.winnerScore != null && m.loserScore != null;
              const pad2 = n => String(n).padStart(2, ' ');
            %>
            <div class="match-pair">
              <div class="team-card <%= leftClass %>">
                <%= left ? left.label : '?' %>
              </div>
              <div class="match-connector">
                <% if (hasScore) { %>
                  <span class="match-score"><%= pad2(m.winnerScore) %> <%= pad2(m.loserScore) %></span>
                <% } %>
              </div>
              <div class="team-card <%= rightClass %>">
                <%= right ? right.label : '?' %>
              </div>
            </div>
          <% }); %>

          <% stage.byes.forEach(byeIdx => { %>
            <div class="team-card bye">
              <%= view.teams[byeIdx].label %> <span class="bye-tag">bye</span>
            </div>
          <% }); %>
        </div>
      <% }); %>
    </div>
  <% } %>
<% } %>
